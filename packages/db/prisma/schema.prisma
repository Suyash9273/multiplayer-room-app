generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Defines the purpose of the room to help the backend route events correctly
// and apply specific cleanup logic (e.g., deleting ANONYMOUS rooms on disconnect)
enum RoomType {
  DIRECT
  GROUP
  ANONYMOUS
}

// CORE CHAT MODELS

model Room {
  id        String       @id @default(uuid())
  type      RoomType     @default(DIRECT)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relational links
  members   RoomMember[]
  messages  Message[]
}

model RoomMember {
  id        String   @id @default(uuid())
  
  // Link back to the specific Room
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  // Link to an authenticated User (Nullable for anonymous chats)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Link to a temporary Guest (Nullable for standard user chats)
  guestId   String?
  guest     GuestIdentity? @relation(fields: [guestId], references: [id], onDelete: Cascade)

  joinedAt  DateTime @default(now())

  // Constraints: A specific user or guest can only join a specific room once
  @@unique([roomId, userId])
  @@unique([roomId, guestId])
}

// Represents a temporary user in the Omegle-style system.
//
// IMPORTANT: identity here is NOT tied to a socket connection.
// socket.id changes every time a browser reconnects (refresh, flaky wifi),
// so keying identity off it would orphan the guest's RoomMember rows on
// every reconnect. Instead, `token` is a durable, server-issued secret
// that lives in an httpOnly cookie on the client and is looked up the
// exact same way we already look up Session.token for real users.
model GuestIdentity {
  id          String    @id @default(uuid())

  // Opaque, unguessable secret. Never sent anywhere except set as an
  // httpOnly cookie. This — not socketId — is what proves "this browser
  // owns this guest identity" across reconnects.
  token       String    @unique

  // Human-friendly label generated server-side at mint time (e.g. "Stranger-4821").
  // Never trust a client-supplied display name for guests.
  displayName String

  // Last-seen socket, kept only for observability/debugging (which live
  // connection currently represents this guest). NOT unique, NOT the
  // identity key, and it's fine for it to be null while disconnected.
  socketId    String?

  // Future-proofing: Array of tags for Phase 4 interest-based matchmaking
  interests   String[]

  createdAt   DateTime  @default(now())
  // Guests are inherently temporary — this lets a cleanup job reap old
  // anonymous identities (and cascade their RoomMember rows) safely.
  expiresAt   DateTime

  roomMembers RoomMember[]
}


model Message {
  id                String   @id @default(uuid())
  
  // Strongly bound to a relational Room, preventing unauthorized string-guessing
  roomId            String
  room              Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  message           String
  
  // Who sent it? Nullable so system messages don't need a sender ID
  senderId          String?  
  // We store the display name at the time of sending (e.g., "Stranger", "Alice").
  // This avoids massive frontend joins just to display the sender's name.
  senderDisplayName String   
  
  type              String   @default("USER")
  createdAt         DateTime @default(now())

  isRead            Boolean   @default(false)
  readAt            DateTime?
}

// --- BETTER AUTH CORE TABLES ---

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  username      String?   @unique
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  sentFriendships     Friendship[] @relation("SentFriendships")
  receivedFriendships Friendship[] @relation("ReceivedFriendships")

  // NEW: Back-relation connecting the User to the rooms they belong to
  roomMembers         RoomMember[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
} 

model Friendship {
  id         String   @id @default(cuid())

  senderId   String
  receiverId String

  status     String   @default("PENDING")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender      User @relation("SentFriendships", fields: [senderId], references: [id])
  receiver    User @relation("ReceivedFriendships", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}
