{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @multiplayer/db exec prisma generate"
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter @multiplayer/db exec prisma migrate deploy",
    "startCommand": "pnpm --filter server start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}